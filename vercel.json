    { "source": "/api/health", "destination": "/api/router?route=health" },
    { "source": "/api/store-auth", "destination": "/api/router?route=store-auth" },
    { "source": "/api/store", "destination": "/api/router?route=store" },
    { "source": "/api/store-link", "destination": "/api/router?route=store-link" },
    { "source": "/api/store-purchase", "destination": "/api/router?route=store-purchase" },
    { "source": "/api/store-purchase-cart", "destination": "/api/router?route=store-purchase-cart" },
    { "source": "/api/store-admin", "destination": "/api/router?route=store-admin" },
    { "source": "/api/store-admin-auth", "destination": "/api/router?route=store-admin-auth" },
    { "source": "/api/store-email-auth", "destination": "/api/router?route=store-email-auth" },
    { "source": "/api/store-bridge", "destination": "/api/router?route=store-bridge" },
    { "source": "/api/maintenance", "destination": "/api/router?route=store-maintenance" }
